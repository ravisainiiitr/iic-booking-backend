# Copy these into the server file:
#   iic-booking-backend/.envs/.production/.django
# Then restart django / celery containers.
#
# All app notification emails use Django EMAIL_BACKEND → AWS SES API.

USE_AWS_SES_API=True
AWS_SES_REGION_NAME=ap-south-1
AWS_SES_ACCESS_KEY_ID=REPLACE_WITH_SES_ACCESS_KEY_ID
AWS_SES_SECRET_ACCESS_KEY="REPLACE_WITH_SES_SECRET_ACCESS_KEY"

# Must be a verified identity (email or domain) in SES for this region
DJANGO_DEFAULT_FROM_EMAIL=IIC Booking <iicbooking@iitr.ac.in>
DJANGO_SERVER_EMAIL=IIC Booking <iicbooking@iitr.ac.in>

# Do NOT set these for production email (legacy IITR SMTP):
# AWS_SES_SMTP_HOST=
# AWS_SES_SMTP_USERNAME=
# AWS_SES_SMTP_PASSWORD=
# DJANGO_EMAIL_BACKEND=
