# Copy into the server file:
#   iic-booking-backend/.envs/.production/.django
# Then restart django / celery containers.
#
# Outbound email: IITR SMTP (nsmtp) — same as the EC2 working Python script.

USE_AWS_SES_API=False
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

AWS_SES_SMTP_HOST=nsmtp.iitr.ac.in
AWS_SES_SMTP_PORT=587
AWS_SES_SMTP_USERNAME=iicbooking@iitr.ac.in
AWS_SES_SMTP_PASSWORD="Iiciitr2025@"
AWS_SES_SMTP_USE_TLS=True
AWS_SES_SMTP_USE_SSL=False

DJANGO_DEFAULT_FROM_EMAIL=IIC Booking <iicbooking@iitr.ac.in>
DJANGO_SERVER_EMAIL=IIC Booking <iicbooking@iitr.ac.in>

# Optional later: AWS SES API (leave unused while USE_AWS_SES_API=False)
# AWS_SES_REGION_NAME=ap-south-1
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
